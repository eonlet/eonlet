# Eonlet x-digest agent — environment variables
#
# Copy this file to .env and fill in real values:
#     cp .env.example .env
#     vim .env
#
# .env is gitignored. Never commit it.

# -------------------------------------------------
# X (Twitter) API
# -------------------------------------------------
# Bearer token from https://developer.x.com/en/portal/products
# The free tier does NOT support reading timelines.
# You need Basic ($100/mo) or higher for `users/:id/timelines/reverse_chronological`.
#
# If you don't want to pay, you can modify tools/x_timeline.py to use an
# unofficial library like `twikit` — note that scraping violates X's ToS.
X_BEARER_TOKEN=

# -------------------------------------------------
# SMTP (for sending the daily digest email)
# -------------------------------------------------
# Examples:
#
#   Gmail (with App Password, requires 2FA on Google account):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=587
#     SMTP_USER=you@gmail.com
#     SMTP_PASSWORD=xxxx xxxx xxxx xxxx  (16-char app password)
#
#   Fastmail:
#     SMTP_HOST=smtp.fastmail.com
#     SMTP_PORT=587
#     SMTP_USER=you@fastmail.com
#     SMTP_PASSWORD=<app-specific password>
#
#   Self-hosted / Postfix:
#     SMTP_HOST=mail.yourdomain.com
#     SMTP_PORT=587
#     SMTP_USER=you@yourdomain.com
#     SMTP_PASSWORD=<your password>

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# -------------------------------------------------
# Where to deliver the digest
# -------------------------------------------------
EMAIL_TO=

# -------------------------------------------------
# Optional tuning
# -------------------------------------------------
# Max tweets to fetch per run (default 200; X API has rate limits)
# X_DIGEST_MAX_TWEETS=200
