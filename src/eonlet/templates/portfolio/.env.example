# Eonlet portfolio agent — environment variables
#
# Copy to .env and fill in real values:
#     cp .env.example .env
#     vim .env

# ============================================================================
# BROKER (read-only access to your positions)
# ============================================================================
#
# IMPORTANT: This agent only requires READ access. If your broker lets you
# create read-only API tokens, use them. NEVER give the agent trade-execution
# credentials.
#
# Supported providers:
#
#   Alpaca (default — easiest to get started, supports paper trading):
#     BROKER_PROVIDER=alpaca
#     BROKER_API_KEY=PK...     # from https://app.alpaca.markets/paper/dashboard/overview
#     BROKER_API_SECRET=...
#     BROKER_ACCOUNT_ID=<your-account-id>
#     For paper trading, the API key is automatically scoped to paper.
#
#   Interactive Brokers (requires TWS or IB Gateway running locally):
#     BROKER_PROVIDER=ibkr
#     BROKER_API_KEY=<not used, set anyway>
#     BROKER_ACCOUNT_ID=U1234567
#     (uses ib_insync to connect to localhost:7497)
#
#   No broker (use only watchlist; manually maintain holdings):
#     BROKER_PROVIDER=yfinance_only
#     BROKER_API_KEY=none
#     BROKER_ACCOUNT_ID=manual
#     (portfolio_read returns whatever's in memory/holdings_manual.md)

BROKER_PROVIDER=alpaca
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_ACCOUNT_ID=

# ============================================================================
# MARKET DATA (real-time / EOD quotes)
# ============================================================================
#
# Providers:
#
#   yfinance (default — free, no key needed, 15-min delayed):
#     MARKET_DATA_PROVIDER=yfinance
#     MARKET_DATA_API_KEY=none
#
#   Polygon.io (real-time, paid):
#     MARKET_DATA_PROVIDER=polygon
#     MARKET_DATA_API_KEY=<your-key>
#
#   Tiingo (delayed free / real-time paid):
#     MARKET_DATA_PROVIDER=tiingo
#     MARKET_DATA_API_KEY=<your-key>

MARKET_DATA_PROVIDER=yfinance
MARKET_DATA_API_KEY=none

# ============================================================================
# NEWS (optional)
# ============================================================================
#
# Used by news_scan tool. If not set, news_scan falls back to web_search.
#
#   NewsAPI (https://newsapi.org/):
#     NEWS_API_KEY=<your-key>

NEWS_API_KEY=

# ============================================================================
# EMAIL DELIVERY (SMTP for reports)
# ============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# ============================================================================
# SAFETY REMINDER
# ============================================================================
#
# This agent is configured with `permissions.mode: yolo` and `extra_deny`
# patterns that block any trade execution. If you customize the agent to
# add trading tools, you take on the risk yourself.
#
# Even with read-only API keys, treat this .env file as sensitive.
# It is gitignored by default. Do not commit it.
